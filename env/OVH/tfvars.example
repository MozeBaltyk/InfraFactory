ovh_endpoint           = "ovh-eu"
ovh_application_key    = "xxxxxxxxxxxxxxxx"
ovh_application_secret = "xxxxxxxxxxxxxxxx"
ovh_consumer_key       = "xxxxxxxxxxxxxxxx"
ovh_project_service_name = "xxxxxxxxxxxxxxxx"

cluster = {
  id                  = "factory"
  domain              = "lab"
  timezone            = "Europe/Paris"
  region              = "GRA9"
  username            = "localadmin"
  cloud_init_selected = "k3s"
}

infra = {
  masters = {
    count = 1 # Can be >1; set network.cidr for multi-master/private join
    # instance_size = "b2-7"
    # disk_size     = 40 # custom root disk sizing not supported yet
    # extra_disks = [    # not supported yet
    #   { size_gb = 20, mount_path = "/data", filesystem = "ext4", label = "data" }
    # ]
  }

  workers = {
    count = 0 # Workers are supported
    # instance_size = "b2-7"
    # disk_size     = 40 # custom root disk sizing not supported yet
    # extra_disks   = []  # not supported yet
  }
}

os = {
  selected = "ubuntu24"
}

# OVH private networking and kube-api endpoint mode example
# When network.cidr is set, OVH creates the private network/subnet and
# the kube-api load balancer together. Multi-master requires this.
# network = {
#   cidr                   = "10.0.0.0/24"
#   load_balancer_flavor   = "small"
#   kube_api_endpoint_mode = "lb_ip" # or "dns"
#   kube_api_dns_name      = "api.factory.lab" # required for dns mode; record must exist outside Terraform
# }

