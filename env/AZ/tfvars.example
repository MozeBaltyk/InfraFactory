azure_subscription_id = "xxxxxxxxxxxxxxxxxx"
azure_client_id       = "xxxxxxxxxxxxxxxxxx"
azure_client_secret   = "xxxxxxxxxxxxxxxxxx"
azure_tenant_id       = "xxxxxxxxxxxxxxxxxx"

cluster = {
  id       = "factory"
  domain   = "lab"
  masters  = 1
  workers  = 0
  timezone = "Europe/Paris"
  region = "westeurope"
  username = "localadmin"
  cloud_init_selected = "k3s"
}

infra = {
  instance_size = "standard_d8s_v5"
  disk_size     = 30
}

os = {
  selected = "ubuntu24"
}

# if cloud_init_selected=k3s
k3s = {
  version           = "v1.34.5+k3s1"
  token             = "my-super-secret-shared-token-12345"
  etcd_enabled      = true
  traefik_enabled   = true
  servicelb_enabled = true
  local_storage_enabled = true
  metrics_server_enabled = true
}

